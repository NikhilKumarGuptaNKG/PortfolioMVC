@model PortfolioMVC.Models.Experience
<style>
    /* Input Styling */
    .custom-input {
        background-color: #2a2a3d;
        border: 1px solid #444;
        color: #fff;
    }

        .custom-input:focus {
            border-color: #0d6efd;
            box-shadow: none;
            background-color: #2a2a3d;
            color: #fff;
        }

    /* Labels */
    .form-label {
        font-weight: 500;
    }
</style>
<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="about-card p-4">

            <h4 class="mb-4 text-center fw-bold">Add Experience</h4>

            <form method="post">

                <div class="mb-3">
                    <label class="form-label">Role</label>
                    <input asp-for="Role" class="form-control custom-input" placeholder="e.g. Software Developer" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Company</label>
                    <input asp-for="Company" class="form-control custom-input" placeholder="e.g. Tata Steel" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control custom-input" rows="3"
                              placeholder="Describe your work..."></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Date Range</label>
                    <input asp-for="DateRange" class="form-control custom-input" placeholder="Jan 2024 - Present" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Order</label>
                    <input asp-for="Order" class="form-control custom-input" />
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-light">Back</a>
                    <button class="btn btn-success px-4">Save</button>
                </div>

            </form>

        </div>

    </div>
</div>
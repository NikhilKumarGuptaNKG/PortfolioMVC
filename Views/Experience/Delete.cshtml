@model PortfolioMVC.Models.Experience
<style>
    .about-card {
        border: 1px solid rgba(255, 0, 0, 0.2);
    }

        .about-card:hover {
            transform: scale(1.02);
        }
</style>
<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="about-card p-4 text-center">

            <h4 class="text-danger fw-bold mb-3">
                <i class="bi bi-exclamation-triangle"></i> Delete Experience
            </h4>

            <p class="text-warning">
                Are you sure you want to delete this experience?
            </p>

            <hr />

            <h5 class="fw-semibold mt-3">
                @Model.Role
            </h5>

            <p class="text-info mb-1">
                @Model.Company
            </p>

            <small class="text-muted d-block mb-2">
                @Model.DateRange
            </small>

            <p class="mt-2">
                @Model.Description
            </p>

            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-center gap-3">

                    <button class="btn btn-danger px-4">
                        <i class="bi bi-trash"></i> Delete
                    </button>

                    <a asp-action="Index" class="btn btn-outline-light px-4">
                        Cancel
                    </a>

                </div>
            </form>

        </div>

    </div>
</div>
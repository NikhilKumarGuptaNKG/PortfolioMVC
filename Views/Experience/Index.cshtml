@model List<PortfolioMVC.Models.Experience>
<style>
    /* Timeline Container */
    .timeline {
        position: relative;
        margin-left: 20px;
        padding-left: 20px;
        border-left: 2px solid #444;
    }

    /* Each Item */
    .timeline-item {
        position: relative;
        margin-bottom: 30px;
    }

    /* Dot */
    .timeline-dot {
        position: absolute;
        left: -10px;
        top: 10px;
        width: 14px;
        height: 14px;
        background-color: #0d6efd;
        border-radius: 50%;
    }

    /* Card Hover (same as skills) */
    .about-card {
        background: #1e1e2f;
        color: #fff;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .about-card:hover {
            transform: translateY(-5px) scale(1.01);
        }

    /* Section Title */
    .section-title {
        font-weight: 600;
    }
</style>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0">Experience</h2>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Experience
        </a>
    }
</div>


<div class="timeline">

    @foreach (var item in Model.OrderBy(x => x.Order))
    {
        <div class="timeline-item">

            <div class="timeline-dot"></div>

            <div class="about-card p-4">

                <h5 class="fw-bold mb-1">@item.Role</h5>
                <p class="text-muted mb-1">@item.Company</p>

                <small class="text-secondary">@item.DateRange</small>

                <p class="mt-2">@item.Description</p>

                <div class="mt-3 d-flex gap-2">

                    <a asp-action="Details" asp-route-id="@item.Id"
                       class="btn btn-sm btn-outline-info">
                        <i class="bi bi-eye"></i>
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id"
                           class="btn btn-sm btn-warning">
                            <i class="bi bi-pencil"></i>
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i>
                        </a>
                    }

                </div>

            </div>
        </div>
    }

</div>
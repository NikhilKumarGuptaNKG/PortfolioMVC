<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nikhil Gupta</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-sm">
        <div class="container">

            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-code-slash"></i> Nikhil Gupta
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navbarContent">
                <ul class="navbar-nav align-items-center gap-2">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="About" asp-action="Index">About</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Skill" asp-action="Index">Skills</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Experience" asp-action="Index">Experience</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Project" asp-action="Index">Projects</a>
                    </li>

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-semibold" asp-controller="Strength" asp-action="Index">
                                Strengths
                            </a>
                        </li>
                    }

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Contact" asp-action="Index">Contact</a>
                    </li>

                    <li class="nav-item ms-3">
                        <partial name="_LoginPartial" />
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main class="container py-5">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="bg-dark text-light mt-5 pt-4 pb-3">
        <div class="container text-center">

            <h5 class="fw-semibold">Nikhil Gupta</h5>
            <p class="text-muted mb-2">ASP.NET Developer | Full Stack Learner</p>

            <div class="mb-3">
                <a href="#" class="text-light mx-2"><i class="bi bi-github"></i></a>
                <a href="#" class="text-light mx-2"><i class="bi bi-linkedin"></i></a>
                <a href="#" class="text-light mx-2"><i class="bi bi-envelope"></i></a>
            </div>

            <small class="text-muted">
                © 2026 Nikhil Gupta. All Rights Reserved.
            </small>

        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
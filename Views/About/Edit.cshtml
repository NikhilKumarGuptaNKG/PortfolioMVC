@model PortfolioMVC.Models.About
<style>
    /* Form Card */
    .about-card {
        background: rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        backdrop-filter: blur(12px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }

    /* Section Titles */
    .section-title {
        border-left: 4px solid #4dabf7;
        padding-left: 10px;
        margin-bottom: 15px;
        font-weight: 600;
        color: #fff;
    }

    /* Inputs */
    .form-control {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.2);
        color: #fff;
    }

        .form-control::placeholder {
            color: #aaa;
        }

    /* Labels */
    .form-label {
        color: #ddd;
        font-weight: 500;
    }

    /* Buttons */
    .btn-primary {
        background: linear-gradient(135deg, #4dabf7, #228be6);
        border: none;
    }

        .btn-primary:hover {
            background: linear-gradient(135deg, #339af0, #1c7ed6);
        }</style>
<section class="mt-5">

    <form method="post" class="about-card p-4" enctype="multipart/form-data">

        <input type="hidden" asp-for="Id" />

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold">
                <i class="bi bi-pencil-square icon"></i> Edit Profile
            </h4>
        </div>

        <!-- BASIC INFO -->
        <h6 class="section-title">Basic Information</h6>

        <div class="mb-3">
            <label class="form-label">Title</label>
            <input asp-for="Title" class="form-control" placeholder="Enter your title" />
        </div>

        <div class="mb-3">
            <label class="form-label">Summary</label>
            <textarea asp-for="Content" class="form-control" rows="3" placeholder="Short introduction"></textarea>
        </div>

        <!-- COMPANY SECTION -->
        <h6 class="section-title mt-4">Work Details</h6>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Company</label>
                <input asp-for="Company" class="form-control" placeholder="Company name" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Location</label>
                <input asp-for="WorkLocation" class="form-control" placeholder="Work location" />
            </div>
        </div>

        <!-- ROLE -->
        <div class="mb-3">
            <label class="form-label">Role</label>
            <textarea asp-for="Role" class="form-control" rows="2"></textarea>
        </div>

        <!-- OVERVIEW -->
        <div class="mb-3">
            <label class="form-label">Industrial Overview</label>
            <textarea asp-for="Overview" class="form-control" rows="3"></textarea>
        </div>
        <!-- Resume -->
        <div class="mb-3">
            <label class="form-label">Upload Resume (PDF)</label>
            <input type="file" asp-for="ResumeFile" class="form-control" accept=".pdf" />
        </div>

        @if (!string.IsNullOrEmpty(Model.ResumeUrl))
        {
            <div class="mb-3">
                <a href="@Model.ResumeUrl" target="_blank" class="btn btn-outline-info">
                    <i class="bi bi-file-earmark-pdf"></i> View Current Resume
                </a>
            </div>
        }
       
        <!-- ACTIONS -->
        <div class="d-flex justify-content-between mt-4">

            <a asp-action="Index" class="btn btn-outline-light px-4">
                <i class="bi bi-arrow-left"></i> Back
            </a>

            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-circle"></i> Save
            </button>

        </div>
       
    </form>

</section>
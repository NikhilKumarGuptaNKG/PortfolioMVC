@model List<PortfolioMVC.Models.Strength>
<style>
    /* Modal Background Blur */
    .custom-modal {
        backdrop-filter: blur(6px);
    }

    /* Modal Container */
    .modern-modal {
        background: linear-gradient(145deg, #1e1e2f, #2a2a3d);
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
        color: #fff;
    }

        /* Header */
        .modern-modal .modal-header {
            padding-bottom: 0;
        }

        /* Body */
        .modern-modal .modal-body {
            padding-top: 10px;
        }

        /* Footer */
        .modern-modal .modal-footer {
            padding-top: 0;
        }

    /* Inputs */
    .custom-input {
        background-color: #2a2a3d;
        border: 1px solid #444;
        color: #fff;
        border-radius: 8px;
    }

        .custom-input:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.15rem rgba(13, 110, 253, 0.25);
            background-color: #2a2a3d;
            color: #fff;
        }

    /* Buttons */
    .btn {
        border-radius: 8px;
    }

    /* Modal Animation */
    .modal.fade .modal-dialog {
        transform: translateY(20px);
        transition: all 0.3s ease;
    }

    .modal.show .modal-dialog {
        transform: translateY(0);
    }
</style>


<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0">Strengths</h2>

    @if (User.IsInRole("Admin"))
    {
        <!-- CREATE BUTTON -->
        <button class="btn btn-primary mb-4" data-bs-toggle="modal" data-bs-target="#createModal">
            <i class="bi bi-plus-circle"></i> Add Strength
        </button>
    }
</div>
<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-3">

            <div class="about-card text-center p-3 h-100">

                <p class="fw-semibold mb-2">✔ @item.Title</p>

                <div class="d-flex justify-content-center gap-2 mt-2">

                    <!-- EDIT -->
                    <button class="btn btn-sm btn-warning"
                            data-bs-toggle="modal"
                            data-bs-target="#editModal-@item.Id">
                        <i class="bi bi-pencil"></i>
                    </button>

                    <!-- DELETE -->
                    <button class="btn btn-sm btn-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteModal-@item.Id">
                        <i class="bi bi-trash"></i>
                    </button>

                </div>

            </div>

        </div>

        <!-- EDIT MODAL -->
        <div class="modal fade custom-modal" id="editModal-@item.Id">
            <div class="modal-dialog">
                <div class="modal-content modern-modal">

                    <form asp-action="Edit" method="post">
                        <div class="modal-header">
                            <h5>Edit Strength</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>

                        <div class="modal-body">
                            <input type="hidden" name="Id" value="@item.Id" />

                            <label class="form-label">Title</label>
                            <input name="Title" value="@item.Title" class="form-control custom-input" />
                        </div>

                        <div class="modal-footer">
                            <button class="btn btn-success">Save</button>
                            <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
        
        <!-- Delete MODAL -->
        <div class="modal fade custom-modal" id="deleteModal-@item.Id" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content modern-modal modal-danger">

                    <form asp-action="Delete" method="post">

                        <div class="modal-header border-0">
                            <h5 class="modal-title text-danger fw-semibold">
                                <i class="bi bi-exclamation-triangle me-2"></i> Confirm Delete
                            </h5>
                            <button type="button" class="btn-close btn-close-white"
                                    data-bs-dismiss="modal"></button>
                        </div>

                        <div class="modal-body text-center">

                            <p class="mb-2">Are you sure you want to delete this?</p>

                            <p class="fw-bold text-warning fs-5">
                                @item.Title
                            </p>

                            <input type="hidden" name="Id" value="@item.Id" />

                            <p class="text-danger small mt-2">
                                This action cannot be undone.
                            </p>

                        </div>

                        <div class="modal-footer border-0 d-flex justify-content-between">

                            <button type="button"
                                    class="btn btn-outline-light px-4"
                                    data-bs-dismiss="modal">
                                Cancel
                            </button>

                            <button class="btn btn-danger px-4">
                                <i class="bi bi-trash"></i> Delete
                            </button>

                        </div>

                    </form>

                </div>
            </div>
        </div>
    }


</div>
<div class="modal fade custom-modal" id="createModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modern-modal">

            <div class="modal-header border-0">
                <h5 class="modal-title fw-semibold">
                    <i class="bi bi-plus-circle"></i> Add Strength
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form asp-action="Create" method="post">
                <div class="modal-body">

                    <label class="form-label">Title</label>
                    <input name="Title" class="form-control custom-input"
                           placeholder="Enter strength..." />

                </div>

                <div class="modal-footer border-0 d-flex justify-content-between">

                    <button type="button" class="btn btn-outline-light px-4"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button class="btn btn-primary px-4">
                        Save
                    </button>

                </div>
            </form>

        </div>
    </div>
</div>
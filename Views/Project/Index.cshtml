@model List<PortfolioMVC.Models.Project>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0">Projects</h2>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Project
        </a>
    }
</div>

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">

            <div class="about-card p-4 h-100"
                 style="cursor:pointer"
                 onclick="window.location.href='/Project/Details/@item.Id'">

                <h5 class="fw-bold">@item.Title</h5>

                <p class="mt-2 text-muted">
                    @item.Description
                </p>

                <small class="text-info">
                    <b>Tech:</b> @item.Technologies
                </small>

                <div class="mt-3 d-flex gap-2">

                    <a href="/Project/Details/@item.Id"
                       class="btn btn-sm btn-outline-info"
                       onclick="event.stopPropagation();">
                        <i class="bi bi-eye"></i>
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a href="/Project/Edit/@item.Id"
                           class="btn btn-sm btn-warning"
                           onclick="event.stopPropagation();">
                            <i class="bi bi-pencil"></i>
                        </a>

                        <a href="/Project/Delete/@item.Id"
                           class="btn btn-sm btn-danger"
                           onclick="event.stopPropagation();">
                            <i class="bi bi-trash"></i>
                        </a>
                    }

                </div>

            </div>

        </div>
    }

</div>
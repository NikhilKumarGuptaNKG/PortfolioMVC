@model List<PortfolioMVC.Models.Project>

<h2>Projects</h2>

<a href="/Project/Create" class="btn btn-primary">Add Project</a>

<table class="table mt-3">
    <tr>
        <th>Title</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Title</td>
            <td>
                <a href="/Project/Edit/@item.Id">Edit</a> |
                <a href="/Project/Delete/@item.Id">Delete</a>
            </td>
        </tr>
    }
</table>
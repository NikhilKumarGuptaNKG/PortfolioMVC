@model List<PortfolioMVC.Models.Project>

<style>
    /* Project Card */
    .project-card {
        background: rgba(255,255,255,0.06);
        border-radius: 12px;
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        border: 1px solid rgba(255,255,255,0.08);
        cursor: pointer;
    }

        .project-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        }

    /* Tech badges */
    .tech-badge {
        background: rgba(77, 171, 247, 0.15);
        color: #4dabf7;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        margin-right: 5px;
        display: inline-block;
        margin-top: 5px;
    }

    /* Text */
    .text-muted-light {
        color: #cbd5e1;
    }

    /* Image */
    .project-img-wrapper {
        height: 180px;
        overflow: hidden;
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
    }

    .project-img-top {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .project-card:hover .project-img-top {
        transform: scale(1.08);
    }

    /* Carousel dots */
    .carousel-indicators button {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }
</style>

<!-- HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0">Projects</h2>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Project
        </a>
    }
</div>

<!-- PROJECT GRID -->
<div class="row mt-4">

    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">

            <!-- CLICKABLE CARD -->
            <div class="project-card h-100">

                <!-- IMAGE CAROUSEL -->
                @{
                    var images = item.ImageUrls?.Split(',', StringSplitOptions.RemoveEmptyEntries);
                }

                @if (images != null && images.Length > 0)
                {
                    <div id="carousel-@item.Id"
                         class="carousel slide carousel-fade"
                         data-bs-ride="carousel"
                         data-bs-pause="hover"
                         data-bs-interval="2500">

                        <!-- Indicators -->
                        <div class="carousel-indicators">
                            @for (int i = 0; i < images.Length; i++)
                            {
                                <button type="button"
                                        data-bs-target="#carousel-@item.Id"
                                        data-bs-slide-to="@i"
                                        class="@(i == 0 ? "active" : "")">
                                </button>
                            }
                        </div>

                        <!-- Slides -->
                        <div class="carousel-inner">
                            @for (int i = 0; i < images.Length; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    <div class="project-img-wrapper">
                                        <img src="@images[i]" class="project-img-top" />
                                    </div>
                                </div>
                            }
                        </div>

                    </div>
                }

                <!-- CONTENT -->
                <div class="p-3">

                    <h5 class="fw-bold">@item.Title</h5>

                    <p class="text-muted-light small">
                        @item.Description
                    </p>

                    <!-- TECH -->
                    <div class="mt-2">
                        @foreach (var tech in item.Technologies?.Split(',') ?? new string[] { })
                        {
                            <span class="tech-badge">@tech.Trim()</span>
                        }
                    </div>

                    <!-- ACTION BAR -->
                    <div class="mt-3 d-flex justify-content-between align-items-center">
                        <a href="/Project/Details/@item.Id"
                           class="btn btn-sm"
                           onclick="event.stopPropagation();">
                            <span class="text-info">
                                <i class="bi bi-eye"></i> View Details
                            </span>
                        </a>
                        

                        <div class="d-flex gap-2">

                            @if (User.IsInRole("Admin"))
                            {
                                <a href="/Project/Edit/@item.Id"
                                   class="btn btn-sm btn-warning"
                                   onclick="event.stopPropagation();">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a href="/Project/Delete/@item.Id"
                                   class="btn btn-sm btn-danger"
                                   onclick="event.stopPropagation();">
                                    <i class="bi bi-trash"></i>
                                </a>
                            }

                        </div>

                    </div>

                </div>

            </div>

        </div>
    }

</div>
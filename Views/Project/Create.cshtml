@model PortfolioMVC.Models.Project

<style>
    .custom-input {
        background-color: #2a2a3d;
        border: 1px solid #444;
        color: #fff;
    }

        .custom-input:focus {
            border-color: #0d6efd;
            box-shadow: none;
            background-color: #2a2a3d;
            color: #fff;
        }

    .section-title {
        font-weight: 600;
        margin-bottom: 6px;
    }
</style>

<div class="container mt-5">

    <form method="post" enctype="multipart/form-data" class="about-card p-4">

        <h3 class="mb-4">
            <i class="bi bi-plus-circle icon"></i> Add New Project
        </h3>

        <!-- TITLE -->
        <div class="mb-3">
            <label class="form-label section-title">Project Title</label>
            <input asp-for="Title" class="form-control custom-input" />
        </div>

        <!-- DESCRIPTION (Purpose / Overview) -->
        <div class="mb-3">
            <label class="form-label section-title">Description</label>
            <textarea asp-for="Description" class="form-control custom-input" rows="3"></textarea>
        </div>

        <!-- ARCHITECTURE -->
        <div class="mb-3">
            <label class="form-label section-title">Architecture</label>
            <textarea asp-for="Architecture" class="form-control custom-input" rows="4"></textarea>
        </div>

        <!-- MY ROLE -->
        <div class="mb-3">
            <label class="form-label section-title">My Role</label>
            <input asp-for="MyRole" class="form-control custom-input" />
        </div>

        <!-- TECHNOLOGIES -->
        <div class="mb-3">
            <label class="form-label section-title">Technologies</label>
            <input asp-for="Technologies" class="form-control custom-input" />
        </div>

        <!-- CONTRIBUTION -->
        <div class="mb-3">
            <label class="form-label section-title">Contribution</label>
            <textarea asp-for="Contribution" class="form-control custom-input" rows="4"></textarea>
        </div>

        <!-- OUTCOME -->
        <div class="mb-3">
            <label class="form-label section-title">Outcome</label>
            <textarea asp-for="Outcome" class="form-control custom-input" rows="3"></textarea>
        </div>

        <!-- IMAGE UPLOAD -->
        <div class="mb-3">
            <label class="form-label section-title">Upload Images</label>
            <input type="file" asp-for="Images" multiple class="form-control custom-input" />
        </div>

        <!-- BUTTONS -->
        <div class="mt-4 d-flex justify-content-between">

            <a href="javascript:history.back()" class="btn btn-outline-light">
                ← Back
            </a>

            <button type="submit" class="btn btn-success">
                <i class="bi bi-check-circle"></i> Save Project
            </button>

        </div>

    </form>

</div>
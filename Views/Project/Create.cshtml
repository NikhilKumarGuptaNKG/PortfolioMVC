@model PortfolioMVC.Models.Project
<style>
    .custom-input {
        background-color: #2a2a3d;
        border: 1px solid #444;
        color: #fff;
    }

        .custom-input:focus {
            border-color: #0d6efd;
            box-shadow: none;
            background-color: #2a2a3d;
            color: #fff;
        }
</style>
<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="about-card p-4">

            <h4 class="mb-4 text-center fw-bold">Add Project</h4>

            <form method="post">

                <div class="mb-3">
                    <label class="form-label">Title</label>
                    <input asp-for="Title" class="form-control custom-input"
                           placeholder="Project Title" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control custom-input"
                              rows="3"
                              placeholder="Describe your project..."></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Technologies</label>
                    <input asp-for="Technologies" class="form-control custom-input"
                           placeholder="e.g. ASP.NET, SQL, React" />
                </div>

                <div class="d-flex justify-content-between mt-4">

                    <a asp-action="Index" class="btn btn-outline-light">
                        ← Back
                    </a>

                    <button type="submit" class="btn btn-success px-4">
                        Save
                    </button>

                </div>

            </form>

        </div>

    </div>
</div>
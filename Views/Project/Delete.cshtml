@model PortfolioMVC.Models.Project

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="about-card p-4 text-center">

            <h4 class="text-danger fw-bold mb-3">
                <i class="bi bi-exclamation-triangle"></i> Delete Project
            </h4>

            <p class="text-warning">
                Are you sure you want to delete this project?
            </p>

            <hr />

            <h5 class="fw-semibold mt-3">
                @Model.Title
            </h5>

            <p class="text-muted mt-2">
                @Model.Description
            </p>

            <small class="text-info d-block mb-3">
                <b>Tech:</b> @Model.Technologies
            </small>

            <p class="text-danger fw-semibold">
                This action cannot be undone.
            </p>

            <form method="post" class="mt-4">
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-center gap-3">

                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash"></i> Delete
                    </button>

                    <a href="/Project" class="btn btn-outline-light px-4">
                        Cancel
                    </a>

                </div>
            </form>

        </div>

    </div>
</div>
@model PortfolioMVC.Models.Project

<div class="container mt-5">

    <form method="post" enctype="multipart/form-data" class="about-card p-4">

        <input type="hidden" asp-for="Id" />

        <h3 class="mb-4">
            <i class="bi bi-pencil-square icon"></i> Edit Project
        </h3>

        <!-- TITLE -->
        <div class="mb-3">
            <label>Title</label>
            <input asp-for="Title" class="form-control" />
        </div>

        <!-- OVERVIEW -->
        <div class="mb-3">
            <label>Overview</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>

        <!-- ARCHITECTURE -->
        <div class="mb-3">
            <label>Architecture</label>
            <textarea asp-for="Architecture" class="form-control" rows="4"></textarea>
        </div>

        <!-- CONTRIBUTION -->
        <div class="mb-3">
            <label>Contribution</label>
            <textarea asp-for="Contribution" class="form-control" rows="4"></textarea>
        </div>

        <!-- TECHNOLOGIES -->
        <div class="mb-3">
            <label>Technologies</label>
            <input asp-for="Technologies" class="form-control" />
        </div>

        <!-- EXISTING IMAGES -->
        <div class="mb-3">
            <label>Existing Images</label>

            <div class="row">
                @{
                    var images = Model.ImageUrls?.Split(',');
                }

                @if (images != null)
                {
                    foreach (var img in images)
                    {
                        <div class="col-md-3 mb-2 text-center">

                            <img src="@img"
                                 class="img-fluid rounded shadow mb-1"
                                 style="height:120px; object-fit:cover;" />

                            <!-- REMOVE BUTTON -->
                            <button type="button"
                                    class="btn btn-sm btn-danger"
                                    onclick="removeImage('@img', this)">
                                Remove
                            </button>

                        </div>
                    }
                }
            </div>

            <!-- HIDDEN FIELD -->
            <input type="hidden" id="RemainingImages" name="RemainingImages" value="@Model.ImageUrls" />
        </div>

        <!-- UPLOAD NEW IMAGES -->
        <div class="mb-3">
            <label>Upload New Images</label>
            <input type="file" name="Images" multiple class="form-control" />
            <small class="text-muted">Uploading will add more images</small>
        </div>

        <!-- BUTTONS -->
        <div class="mt-4 d-flex justify-content-between">

            <a href="javascript:history.back()" class="btn btn-outline-light">
                ← Back
            </a>

            <button type="submit" class="btn btn-success">
                Save Changes
            </button>

        </div>

    </form>

</div>
<script>
    function removeImage(imagePath, btn) {

        let hiddenField = document.getElementById("RemainingImages");
        let images = hiddenField.value.split(',');

        // remove selected image
        images = images.filter(x => x !== imagePath);

        hiddenField.value = images.join(',');

        // remove from UI
        btn.parentElement.remove();
    }
</script>
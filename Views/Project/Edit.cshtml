@model PortfolioMVC.Models.Project

<style>
    .custom-input {
        background-color: #2a2a3d;
        border: 1px solid #444;
        color: #fff;
    }

        .custom-input:focus {
            border-color: #0d6efd;
            box-shadow: none;
            background-color: #2a2a3d;
            color: #fff;
        }

    .section-title {
        font-weight: 600;
        margin-bottom: 5px;
    }

    .img-box {
        position: relative;
    }

    .remove-btn {
        position: absolute;
        bottom: 5px;
        left: 50%;
        transform: translateX(-50%);
    }
</style>

<div class="container mt-5">

    <form method="post" enctype="multipart/form-data" class="about-card p-4">

        <input type="hidden" asp-for="Id" />

        <h3 class="mb-4">
            <i class="bi bi-pencil-square icon"></i> Edit Project
        </h3>

        <!-- TITLE -->
        <div class="mb-3">
            <label class="section-title">Title</label>
            <input asp-for="Title" class="form-control custom-input" />
        </div>

        <!-- DESCRIPTION -->
        <div class="mb-3">
            <label class="section-title">Description</label>
            <textarea asp-for="Description" class="form-control custom-input" rows="3"></textarea>
        </div>

        <!-- ARCHITECTURE -->
        <div class="mb-3">
            <label class="section-title">Architecture</label>
            <textarea asp-for="Architecture" class="form-control custom-input" rows="4"></textarea>
        </div>

        <!-- MY ROLE -->
        <div class="mb-3">
            <label class="section-title">My Role</label>
            <input asp-for="MyRole" class="form-control custom-input" />
        </div>

        <!-- TECHNOLOGIES -->
        <div class="mb-3">
            <label class="section-title">Technologies (comma separated)</label>
            <input asp-for="Technologies" class="form-control custom-input" />
        </div>

        <!-- CONTRIBUTION -->
        <div class="mb-3">
            <label class="section-title">Contribution</label>
            <textarea asp-for="Contribution" class="form-control custom-input" rows="4"></textarea>
        </div>

        <!-- OUTCOME -->
        <div class="mb-3">
            <label class="section-title">Outcome</label>
            <textarea asp-for="Outcome" class="form-control custom-input" rows="3"></textarea>
        </div>

        <!-- EXISTING IMAGES -->
        <div class="mb-3">
            <label class="section-title">Existing Images</label>

            <div class="row">
                @{
                    var images = Model.ImageUrls?.Split(',', StringSplitOptions.RemoveEmptyEntries);
                }

                @if (images != null)
                {
                    foreach (var img in images)
                    {
                        <div class="col-md-3 mb-3 text-center img-box">

                            <img src="@img"
                                 class="img-fluid rounded shadow"
                                 style="height:120px; object-fit:cover;" />

                            <button type="button"
                                    class="btn btn-sm btn-danger remove-btn"
                                    onclick="removeImage('@img', this)">
                                Remove
                            </button>

                        </div>
                    }
                }
            </div>

            <!-- HIDDEN FIELD -->
            <input type="hidden" id="RemainingImages" name="RemainingImages" value="@Model.ImageUrls" />
        </div>

        <!-- UPLOAD NEW IMAGES -->
        <div class="mb-3">
            <label class="section-title">Upload New Images</label>
            <input type="file" asp-for="Images" multiple class="form-control custom-input" />
            <small class="text-muted">New images will be added to existing ones</small>
        </div>

        <!-- BUTTONS -->
        <div class="mt-4 d-flex justify-content-between">

            <a href="javascript:history.back()" class="btn btn-outline-light">
                ← Back
            </a>

            <button type="submit" class="btn btn-success">
                Save Changes
            </button>

        </div>

    </form>

</div>

<script>
    function removeImage(imagePath, btn) {

        let hiddenField = document.getElementById("RemainingImages");
        let images = hiddenField.value
            ? hiddenField.value.split(',').filter(x => x)
            : [];

        // remove selected image
        images = images.filter(x => x !== imagePath);

        hiddenField.value = images.join(',');

        // remove from UI
        btn.closest('.img-box').remove();
    }
</script>
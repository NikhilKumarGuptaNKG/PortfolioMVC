@model PortfolioMVC.Models.Education
@{
    Layout = null;
}

<form id="eduDeleteForm">

    <input type="hidden" name="id" value="@Model.Id" />

    <div class="text-center">
        <p>Delete this education?</p>
        <p class="fw-bold text-warning">@Model.Degree</p>
        <small class="text-danger">This action cannot be undone</small>
    </div>

    <button class="btn btn-danger w-100 mt-3">
        <i class="bi bi-trash"></i> Delete
    </button>

</form>

<script>
    $('#eduDeleteForm').submit(function (e) {
        e.preventDefault();

        $.post('/Home/DeleteEducationConfirmed', $(this).serialize(), function () {
            location.reload();
        });
    });
</script>
@model PortfolioMVC.Models.Education
@{
    Layout = null;
}

<form id="eduForm">

    <input name="Degree" class="form-control custom-input mb-2" placeholder="Degree" />
    <input name="Institute" class="form-control custom-input mb-2" placeholder="Institute" />
    <input name="Year" class="form-control custom-input mb-2" placeholder="Year" />
    <input name="Order" type="number" class="form-control custom-input mb-2" placeholder="Order" />

    <button class="btn btn-success w-100">
        <i class="bi bi-check-circle"></i> Save
    </button>

</form>

<script>
    $('#eduForm').submit(function (e) {
        e.preventDefault();

        $.post('/Home/CreateEducation', $(this).serialize(), function () {
            location.reload();
        });
    });
</script>
@model PortfolioMVC.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Home Page";
}
<style>
    
    /* Modal Background Blur */
    .custom-modal {
        backdrop-filter: blur(6px);
    }

    /* Modal Container */
    .modern-modal {
        background: linear-gradient(145deg, #1e1e2f, #2a2a3d);
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
        color: #fff;
    }

        /* Header */
        .modern-modal .modal-header {
            padding-bottom: 0;
        }

        /* Body */
        .modern-modal .modal-body {
            padding-top: 10px;
        }

        /* Footer */
        .modern-modal .modal-footer {
            padding-top: 0;
        }

    /* Inputs */
    .custom-input {
        background-color: #2a2a3d;
        border: 1px solid #444;
        color: #fff;
        border-radius: 8px;
    }

        .custom-input:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.15rem rgba(13, 110, 253, 0.25);
            background-color: #2a2a3d;
            color: #fff;
        }

    /* Buttons */
    .btn {
        border-radius: 8px;
    }

    /* Modal Animation */
    .modal.fade .modal-dialog {
        transform: translateY(20px);
        transition: all 0.3s ease;
    }

    .modal.show .modal-dialog {
        transform: translateY(0);
    }
    /* Smooth card hover */
    .about-card {
        transition: all 0.3s ease;
    }

        .about-card:hover {
            transform: translateY(-6px) scale(1.02);
        }

    /* Section spacing */
    section {
        padding-top: 30px;
        border-top: 1px solid rgba(255,255,255,0.05);
        animation: fadeInUp 0.6s ease;
    }

        /* Hero */
        section:first-child {
            margin-top: 30px;
        }

    /* Project Card */
    .project-card {
        background: rgba(255,255,255,0.06);
        border-radius: 12px;
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        border: 1px solid rgba(255,255,255,0.08);
    }

        /* Hover effect */
        .project-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        }

    /* Tech badges */
    .tech-badge {
        background: rgba(77, 171, 247, 0.15);
        color: #4dabf7;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        margin-right: 5px;
        display: inline-block;
        margin-top: 5px;
    }

    /* Text fix */
    .text-muted-light {
        color: #cbd5e1;
    }

    /* Hover arrow animation */
    .project-card:hover i.bi-arrow-right {
        transform: translateX(5px);
        transition: 0.3s;
    }

    /* Project Image */
    .project-img-wrapper {
        height: 180px;
        overflow: hidden;
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
    }

    .project-img-top {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .project-card:hover .project-img-top {
        transform: scale(1.08);
    }
    
   
    .exp-card {
        border-left: 4px solid #4dabf7;
    }
    /* HERO */
    .hero {
        margin-top: 20px;
    }

    /* COVER */
    .hero-cover {
        height: 420px;
        background-size: auto;
        background-position: left;
        /* background-size: cover;
        background-position: center; */
        border-radius: 12px;
        position: relative;
        display: flex;
        align-items: flex-end;
        box-shadow: 0 15px 40px rgba(0,0,0,0.5);
    }

    /* OVERLAY (important for readability) */
    .hero-overlay {
        position: absolute;
        inset: 0;
        border-radius: 12px;
        background: linear-gradient( to top, rgba(0,0,0,0.85), rgba(0,0,0,0.2) );
    }

    /* CONTENT */
    .hero-content {
        position: relative;
        z-index: 2;
    }

    /* AVATAR */
    .hero-avatar {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #fff;
    }

    /* TEXT BLOCK */
    .text-block {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    /* Better spacing */
    .hero-name {
        font-size: 24px;
        margin-bottom: 2px;
    }

    .hero-role {
        font-size: 14px;
        color: #4dabf7;
    }


    .hero-desc {
        color: #e2e8f0;
        font-size: 14px;
        /* max-width: 700px; */
    }

    .blur-box {
        background: rgba(20,20,30,0.65);
        backdrop-filter: blur(8px);
        border-radius: 12px;
        padding: 15px 20px;
    }
    /* Top box (profile + name) */
    .hero-top-box {
        border-top-left-radius: 0;
        border-top-right-radius: 0;
    }

    @@media (max-width: 768px) {
        .hero-content .d-flex {
            justify-content: center !important;
            text-align: center;
        }

        .text-block {
            align-items: center;
        }
    }
</style>
<!--Hero Section-->
<section class="hero">

    <div class="hero-cover"
         style="background-image:url('@Model.About?.CoverImageUrl')">

        <!-- DARK GRADIENT (for readability) -->
        <div class="hero-overlay"></div>

        <!-- CONTENT (BOTTOM) -->
        <div class="hero-content container">

            <div class="row align-items-end">
                <div class="col-md-12 blur-box hero-top-box">
                    <div class="text-center mt-2">
                        <div class="d-flex align-items-center gap-3 flex-wrap justify-content-center">

                            <!-- PROFILE -->
                            @if (!string.IsNullOrEmpty(Model.About?.ProfileImageUrl))
                            {
                                <img src="@Model.About.ProfileImageUrl" class="hero-avatar" />
                            }

                            <!-- TEXT (RIGHT SIDE) -->
                            <div class="text-block">
                                <h2 class="hero-name mb-0">Nikhil Gupta</h2>
                                <p class="hero-role mb-0">ASP.NET Developer | Full Stack Learner</p>
                            </div>

                        </div>
                    </div>
                    
                    <p class="hero-desc">
                        @Model.About?.Content
                    </p>
                    <div class="text-center mt-2">
                        <a href="#projects" class="btn btn-primary btn-sm">
                            🚀 View Projects
                        </a>
                    </div>
                </div>
            </div>

        </div>

    </div>

</section>

<!-- EXPERIENCE -->
<section class="mt-5">
    <h2 class="section-title">Experience</h2>

    @foreach (var exp in Model.Experiences)
    {
        <div class="about-card mb-3" style="cursor:pointer" onclick="window.location.href='/Experience/Details/@exp.Id'">
            <h5 class="fw-bold">@exp.Role - @exp.Company</h5>
            <small class="text-muted">@exp.DateRange</small>
            <p class="mt-2">@exp.Description</p>
        </div>
    }
</section>

<!-- SKILLS -->
<section class="mt-5" id="skills">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title mb-0">Skills</h2>

        @if (User.IsInRole("Admin"))
        {
            <a class="btn btn-primary" onclick="openCreate()">
                <i class="bi bi-plus-circle"></i> Add Skill
            </a>
        }
    </div>

   @*  <h2 class="section-title">Skills</h2> *@

    <div class="row mt-4">
        @foreach (var skill in Model.Skills)
        {
            <div class="col-md-3 col-6 mb-3">
                <div class="about-card text-center p-3"
                     style="cursor:pointer"
                     onclick="window.location.href='/Skill/Details/@skill.Id'">

                    <p class="mt-2 mb-0 fw-semibold">@skill.Name</p>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="mt-3 d-flex justify-content-center gap-2">

                            <!-- Details button (optional now) -->
                            <a asp-controller="Skill" asp-action="Details" asp-route-id="@skill.Id"
                               class="btn btn-sm btn-outline-light"
                               onclick="event.stopPropagation();">
                                <i class="bi bi-eye"></i>
                            </a>

                            <!-- Edit -->
                            <button class="btn btn-sm btn-warning"
                                    onclick="event.stopPropagation(); openEdit(@skill.Id)">
                                <i class="bi bi-pencil"></i>
                            </button>

                            <!-- Delete -->
                            <button class="btn btn-sm btn-danger"
                                    onclick="event.stopPropagation(); openDelete(@skill.Id)">
                                <i class="bi bi-trash"></i>
                            </button>

                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>
<!--Projects Section-->
<section id="projects" class="mt-5">
    <h2 class="section-title">Projects</h2>

    <div class="row mt-4">
        @foreach (var project in Model.Projects)
        {
            <div class="col-md-4 mb-4">
                <a href="/Project/Details/@project.Id" class="text-decoration-none">
                    <div class="project-card h-100">

                        <!-- IMAGE -->
                        @{
                            var images = project.ImageUrls?.Split(',', StringSplitOptions.RemoveEmptyEntries);
                        }

                        @if (images != null && images.Length > 0)
                        {
                            <div id="carousel-@project.Id"
                                 class="carousel slide carousel-fade"
                                 data-bs-ride="carousel"
                                 data-bs-pause="hover"
                                 data-bs-interval="2500">

                                <div class="carousel-inner">

                                    @for (int i = 0; i < images.Length; i++)
                                    {
                                        <div class="carousel-item @(i == 0 ? "active" : "")">

                                            <div class="project-img-wrapper">
                                                <img src="@images[i]" class="project-img-top" />
                                            </div>

                                        </div>
                                    }

                                </div>

                            </div>
                        }

                        <div class="p-3">

                            <h5 class="fw-bold text-light">@project.Title</h5>

                            <p class="text-muted-light small">
                                @project.Description
                            </p>

                            <div class="mt-2">
                                @foreach (var tech in project.Technologies?.Split(',') ?? new string[] { })
                                {
                                    <span class="tech-badge">@tech.Trim()</span>
                                }
                            </div>

                            <div class="mt-3 d-flex justify-content-between align-items-center">
                                <small class="text-info">
                                    <i class="bi bi-eye"></i> View Details
                                </small>
                                <i class="bi bi-arrow-right text-info"></i>
                            </div>

                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</section>

<!-- EDUCATION -->
<section class="mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title mb-0">Education</h2>

        @if (User.IsInRole("Admin"))
        {
            <button class="btn btn-primary" onclick="openEduCreate()">
                <i class="bi bi-plus-circle"></i> Add Education
            </button>
        }
    </div>

    @foreach (var edu in Model.Educations)
    {
        <div class="about-card mb-3 exp-card">

            <h5 class="fw-bold">@edu.Degree</h5>
            <p class="mb-1">@edu.Institute</p>
            <small class="text-muted">@edu.Year</small>

            @if (User.IsInRole("Admin"))
            {
                <div class="mt-2 d-flex gap-2">

                    <button class="btn btn-sm btn-warning"
                            onclick="openEduEdit(@edu.Id)">
                        <i class="bi bi-pencil"></i>
                    </button>

                    <button class="btn btn-sm btn-danger"
                            onclick="openEduDelete(@edu.Id)">
                        <i class="bi bi-trash"></i>
                    </button>

                </div>
            }

        </div>
    }
</section>

<!-- STRENGTHS -->
<section class="mt-5">
    <h2 class="section-title">Strengths</h2>

    <div class="row mt-3">
        @foreach (var s in Model.Strengths)
        {
            <div class="col-md-4 mb-2">
                <div class="about-card text-center p-2">
                    ✔ @s.Title
                </div>
            </div>
        }
    </div>
</section>

@* skill Modal for Create, Edit, and Delete *@
<div class="modal fade custom-modal" id="skillModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modern-modal">

            <div class="modal-header border-0">
                <h5 class="modal-title fw-semibold">
                    <i class="bi bi-lightning-charge"></i> Skill
                </h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="modalBody">
                <!-- Dynamic content -->
            </div>

        </div>
    </div>
</div>
@* education Modal for Create, Edit, and Delete *@
<div class="modal fade custom-modal" id="eduModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modern-modal">

            <div class="modal-header border-0">
                <h5 class="modal-title">
                    <i class="bi bi-mortarboard"></i> Education
                </h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body" id="eduModalBody">
            </div>

        </div>
    </div>
</div>
<script>
    function openCreate() {
        $.get('/Skill/Create', function (data) {
            $('#modalBody').html(data);

            var modal = new bootstrap.Modal(document.getElementById('skillModal'));
            modal.show();
        });
    }

    function openEdit(id) {
        $.get('/Skill/Edit/' + id, function (data) {
            $('#modalBody').html(data);

            var modal = new bootstrap.Modal(document.getElementById('skillModal'));
            modal.show();
        });
    }

    function openDelete(id) {
        $.get('/Skill/Delete/' + id, function (data) {
            $('#modalBody').html(data);

            var modal = new bootstrap.Modal(document.getElementById('skillModal'));
            modal.show();
        });
    }
     function openEduCreate() {
        $.get('/Home/CreateEducation', function (data) {
            $('#eduModalBody').html(data);
            new bootstrap.Modal(document.getElementById('eduModal')).show();
        });
    }

    function openEduEdit(id) {
        $.get('/Home/EditEducation/' + id, function (data) {
            $('#eduModalBody').html(data);
            new bootstrap.Modal(document.getElementById('eduModal')).show();
        });
    }

    function openEduDelete(id) {
        $.get('/Home/DeleteEducation/' + id, function (data) {
            $('#eduModalBody').html(data);
            new bootstrap.Modal(document.getElementById('eduModal')).show();
        });
    }
</script>
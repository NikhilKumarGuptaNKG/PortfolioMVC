@model PortfolioMVC.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Home Page";
}
<style>
    /* Smooth card hover */
    .about-card {
        transition: all 0.3s ease;
    }

        .about-card:hover {
            transform: translateY(-6px) scale(1.02);
        }

    /* Section spacing */
    section {
        padding-top: 20px;
    }

        /* Hero */
        section:first-child {
            margin-top: 30px;
        }
</style>
<!-- HERO SECTION -->
<section class="text-center py-5">
    <h1 class="fw-bold display-5">Hi, I'm Nikhil Gupta</h1>
    <p class="lead">ASP.NET Developer | Full Stack Learner</p>

    <p class="mt-3">
        @Model.About?.Content
    </p>

    <a href="#projects" class="btn btn-primary mt-3 px-4">View Projects</a>
</section>

<!-- SKILLS -->
<section class="mt-5">
    <h2 class="section-title">Skills</h2>

    <div class="row mt-4">
        @foreach (var skill in Model.Skills)
        {
            <div class="col-md-3 col-6 mb-3">
                <div class="about-card text-center p-3">
                    <p class="mt-2 mb-0 fw-semibold">@skill.Name</p>
                </div>
            </div>
        }
    </div>
</section>

<!-- EXPERIENCE -->
<section class="mt-5">
    <h2 class="section-title">Experience</h2>

    @foreach (var exp in Model.Experiences)
    {
        <div class="about-card mb-3">
            <h5 class="fw-bold">@exp.Role - @exp.Company</h5>
            <small class="text-muted">@exp.DateRange</small>
            <p class="mt-2">@exp.Description</p>
        </div>
    }
</section>

<!-- PROJECTS -->
<section id="projects" class="mt-5">
    <h2 class="section-title">Projects</h2>

    <div class="row mt-4">
        @foreach (var project in Model.Projects)
        {
            <div class="col-md-4 mb-4">
                <a href="/Project/Details/@project.Id" class="text-decoration-none text-light">
                    <div class="about-card h-100">
                        <h5 class="fw-bold">@project.Title</h5>
                        <p>@project.Description</p>
                        <small class="text-info"><b>Tech:</b> @project.Technologies</small>
                    </div>
                </a>
            </div>
        }
    </div>
</section>

<!-- EDUCATION -->
<section class="mt-5">
    <h2 class="section-title">Education</h2>

    @foreach (var edu in Model.Educations)
    {
        <div class="about-card mb-3">
            <h5 class="fw-bold">@edu.Degree</h5>
            <p>@edu.Institute</p>
            <small class="text-muted">@edu.Year</small>
        </div>
    }
</section>

<!-- STRENGTHS -->
<section class="mt-5">
    <h2 class="section-title">Strengths</h2>

    <div class="row mt-3">
        @foreach (var s in Model.Strengths)
        {
            <div class="col-md-4 mb-2">
                <div class="about-card text-center p-2">
                    ✔ @s.Title
                </div>
            </div>
        }
    </div>
</section>

<!-- CONTACT -->
<section class="mt-5 mb-5 text-center">
    <h2 class="section-title">Contact</h2>

    <div class="mt-3">
        <p><i class="bi bi-envelope"></i> @Model.Contact?.Email</p>
        <p><i class="bi bi-telephone"></i> @Model.Contact?.Phone</p>
        <p>
            <i class="bi bi-linkedin"></i>
            <a href="@Model.Contact?.LinkedIn" target="_blank">LinkedIn Profile</a>
        </p>
    </div>
</section>
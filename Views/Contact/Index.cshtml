@model PortfolioMVC.Models.Contact
<style>
    /* Modal Background Blur */
    .custom-modal {
        backdrop-filter: blur(6px);
    }

    /* Modal Container */
    .modern-modal {
        background: linear-gradient(145deg, #1e1e2f, #2a2a3d);
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
        color: #fff;
    }

        /* Header */
        .modern-modal .modal-header {
            padding-bottom: 0;
        }

        /* Body */
        .modern-modal .modal-body {
            padding-top: 10px;
        }

        /* Footer */
        .modern-modal .modal-footer {
            padding-top: 0;
        }

    /* Inputs */
    .custom-input {
        background-color: #2a2a3d;
        border: 1px solid #444;
        color: #fff;
        border-radius: 8px;
    }

        .custom-input:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.15rem rgba(13, 110, 253, 0.25);
            background-color: #2a2a3d;
            color: #fff;
        }

    /* Buttons */
    .btn {
        border-radius: 8px;
    }

    /* Modal Animation */
    .modal.fade .modal-dialog {
        transform: translateY(20px);
        transition: all 0.3s ease;
    }

    .modal.show .modal-dialog {
        transform: translateY(0);
    }
</style>
<h2 class="section-title mb-4">Contact Information</h2>

<div class="row justify-content-center">
    <div class="col-md-8">

        <div class="about-card p-4">

            @if (Model != null)
            {
                <div class="row g-3">

                    <!-- EMAIL -->
                    <div class="col-md-6">
                        <label class="form-label text-muted">Email</label>
                        <span id="view-email" class="d-block">@Model.Email</span>
                        <input id="edit-email" value="@Model.Email"
                               class="form-control d-none custom-input" />
                    </div>

                    <!-- PHONE -->
                    <div class="col-md-6">
                        <label class="form-label text-muted">Phone</label>
                        <span id="view-phone" class="d-block">@Model.Phone</span>
                        <input id="edit-phone" value="@Model.Phone"
                               class="form-control d-none custom-input" />
                    </div>

                    <!-- LINKEDIN -->
                    <div class="col-md-6">
                        <label class="form-label text-muted">LinkedIn</label>
                        <span id="view-linkedin" class="d-block">@Model.LinkedIn</span>
                        <input id="edit-linkedin" value="@Model.LinkedIn"
                               class="form-control d-none custom-input" />
                    </div>

                    <!-- PORTFOLIO -->
                    <div class="col-md-6">
                        <label class="form-label text-muted">Portfolio</label>
                        <span id="view-portfolio" class="d-block">@Model.PortfolioUrl</span>
                        <input id="edit-portfolio" value="@Model.PortfolioUrl"
                               class="form-control d-none custom-input" />
                    </div>

                    <!-- CURRENT -->
                    <div class="col-md-6">
                        <label class="form-label text-muted">Current Address</label>
                        <span id="view-current" class="d-block">@Model.CurrentAdd</span>
                        <input id="edit-current" value="@Model.CurrentAdd"
                               class="form-control d-none custom-input" />
                    </div>

                    <!-- PERMANENT -->
                    <div class="col-md-6">
                        <label class="form-label text-muted">Permanent Address</label>
                        <span id="view-permanent" class="d-block">@Model.ParmanentAdd</span>
                        <input id="edit-permanent" value="@Model.ParmanentAdd"
                               class="form-control d-none custom-input" />
                    </div>

                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="mt-4 d-flex justify-content-center gap-3">

                        <!-- EDIT -->
                        <button id="edit-btn"
                                class="btn btn-warning"
                                onclick="editRow()">
                            <i class="bi bi-pencil"></i> Edit
                        </button>

                        <!-- SAVE -->
                        <button id="save-btn"
                                class="btn btn-success d-none"
                                onclick="saveRow(@Model.Id)">
                            <i class="bi bi-check"></i> Save
                        </button>

                        <!-- CANCEL -->
                        <button id="cancel-btn"
                                class="btn btn-secondary d-none"
                                onclick="cancelEdit()">
                            <i class="bi bi-x"></i> Cancel
                        </button>

                        <!-- DELETE -->
                        <button class="btn btn-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal">
                            <i class="bi bi-trash"></i> Delete
                        </button>

                    </div>
                }
            }

        </div>
    </div>
</div>

<div class="modal fade custom-modal" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content modern-modal modal-danger">

            <form asp-action="Delete" method="post">

                <!-- HEADER -->
                <div class="modal-header border-0">
                    <h5 class="modal-title text-danger fw-semibold">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Confirm Delete
                    </h5>
                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>

                <!-- BODY -->
                <div class="modal-body text-center">

                    <p class="mb-2">Are you sure you want to delete this contact?</p>

                    <!-- Optional highlight (nice UX) -->
                    <p class="fw-bold text-warning">
                        @Model.Email
                    </p>

                    <input type="hidden" name="Id" value="@Model.Id" />

                    <p class="text-danger small mt-3">
                        <i class="bi bi-x-circle"></i>
                        This action cannot be undone
                    </p>

                </div>

                <!-- FOOTER -->
                <div class="modal-footer border-0 d-flex justify-content-between">

                    <button type="button"
                            class="btn btn-outline-light px-4"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button class="btn btn-danger px-4">
                        <i class="bi bi-trash"></i> Delete
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>
<!-- Delete MODAL -->

<script>
    function editRow() {
        toggle(true);
    }

    function cancelEdit() {
        toggle(false);
    }

    function toggle(isEdit) {

        const fields = ["email", "phone", "linkedin", "portfolio", "current", "permanent"];

        fields.forEach(f => {
            document.getElementById(`view-${f}`).style.display = isEdit ? "none" : "block";
            document.getElementById(`edit-${f}`).classList.toggle("d-none", !isEdit);
        });

        document.getElementById(`edit-btn`).classList.toggle("d-none", isEdit);
        document.getElementById(`save-btn`).classList.toggle("d-none", !isEdit);
        document.getElementById(`cancel-btn`).classList.toggle("d-none", !isEdit);
    }

    function saveRow(id) {

        const data = {
            Id: id,
            Email: document.getElementById(`edit-email`).value,
            Phone: document.getElementById(`edit-phone`).value,
            LinkedIn: document.getElementById(`edit-linkedin`).value,
            PortfolioUrl: document.getElementById(`edit-portfolio`).value,
            CurrentAdd: document.getElementById(`edit-current`).value,
            ParmanentAdd: document.getElementById(`edit-permanent`).value
        };

        fetch('/Contact/Edit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(() => location.reload());
    }
</script>